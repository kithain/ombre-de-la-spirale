{
  "name": "ombre-de-la-spirale",
  "description": "Wiki de campagne interactif pour Donjons & Dragons 3.5 - L'Ombre de la Spirale",
  "author": "Kithain",
  "license": "MIT",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/kithain/ombre-de-la-spirale.git"
  },
  "homepage": "https://kithain.github.io/ombre-de-la-spirale/",
  "scripts": {
    "dev": "vite --mode viewer",
    "edit": "start /B node server/index.js && vite --mode editeur",
    "stop": "powershell -Command \"$p=(netstat -aon|Select-String ':3001\\s'|ForEach-Object{($_ -split '\\s+')[-1]}|Select-Object -First 1); if($p){taskkill /F /PID $p}else{Write-Host 'Aucun process sur :3001'}\"",
    "build": "vite build --mode viewer",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:pnj": "node scripts/valider-pnj.js",
    "lint": "eslint .",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "fuse.js": "^6.6.2",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.6.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
